  "definitions": {
    "NewUser": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "example": "firebase-uid"
        },
        "first_name": {
          "type": "string",
          "example": "Jane"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "example": "jane@northeastern.edu"
        },
        "grad_year": {
          "type": "number",
          "example": 2026
        }
      }
    },
    "UpdateUser": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string",
          "example": "Jane"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "example": "jane@northeastern.edu"
        },
        "grad_year": {
          "type": "number",
          "example": 2026
        }
      }
    },
    "Preferences": {
      "type": "object",
      "properties": {
        "wait_for_approval": {
          "type": "boolean",
          "example": false
        },
        "recent_jobs": {
          "type": "boolean",
          "example": true
        },
        "job_match": {
          "type": "string",
          "example": "any"
        },
        "unpaid_roles": {
          "type": "boolean",
          "example": false
        },
        "email_notifications": {
          "type": "boolean",
          "example": true
        }
      }
    },
    "NewApplication": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "example": "job-uuid"
        },
        "status": {
          "type": "string",
          "example": "applied"
        }
      }
    },
    "UpdateApplicationStatus": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "example": "interview"
        }
      }
    },
    "NewTask": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "example": "Submit cover letter"
        },
        "description": {
          "type": "string",
          "example": "Write and submit a tailored cover letter"
        },
        "application_id": {
          "type": "string",
          "example": "app-uuid"
        }
      }
    },
    "AddInstructions": {
      "type": "object",
      "properties": {
        "employer_instructions": {
          "type": "string",
          "example": "Please submit a cover letter and resume via the portal."
        },
        "application_id": {
          "type": "string",
          "example": "app-uuid"
        },
        "company": {
          "type": "string",
          "example": "Acme Corp"
        },
        "title": {
          "type": "string",
          "example": "Software Engineer"
        }
      }
    },
    "ResumeUploadUrl": {
      "type": "object",
      "properties": {
        "file_name": {
          "type": "string",
          "example": "resume.pdf"
        },
        "file_type": {
          "type": "string",
          "example": "application/pdf"
        },
        "file_size": {
          "type": "number",
          "example": 102400
        }
      }
    },
    "SaveResume": {
      "type": "object",
      "properties": {
        "resume_id": {
          "type": "string",
          "example": "resume-uuid"
        },
        "key": {
          "type": "string",
          "example": "s3/path/resume.pdf"
        },
        "user_id": {
          "type": "string",
          "example": "firebase-uid"
        }
      }
    },
    "SendJobDescription": {
      "type": "object",
      "properties": {
        "job_description": {
          "type": "string",
          "example": "We are looking for a full-stack software engineer..."
        },
        "company": {
          "type": "string",
          "example": "Acme Corp"
        },
        "title": {
          "type": "string",
          "example": "Software Engineer Co-op"
        }
      }
    },
    "AddJob": {
      "type": "object",
      "properties": {
        "company": {
          "type": "string",
          "example": "Acme Corp"
        },
        "title": {
          "type": "string",
          "example": "Software Engineer Co-op"
        },
        "description": {
          "type": "string",
          "example": "We are looking for a full-stack software engineer..."
        }
      }
    },
    "UpdateInterests": {
      "type": "object",
      "properties": {
        "interests": {
          "type": "array",
          "example": [
            "software engineering",
            "machine learning"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UpdateJobTypes": {
      "type": "object",
      "properties": {
        "job_types": {
          "type": "array",
          "example": [
            "co-op",
            "full-time"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UpdateSearchTerms": {
      "type": "object",
      "properties": {
        "resume_id": {
          "type": "string",
          "example": "resume-uuid"
        }
      }
    },
    "Error": {
      "type": "object",
      "properties": {
        "status": {
          "type": "number",
          "example": 400
        },
        "message": {
          "type": "string",
          "example": "Validation error message"
        }
      }
    }
  }
